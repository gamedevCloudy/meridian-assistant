# OpenRouter is the only required provider for the prototype.
# Get a key at https://openrouter.ai/keys (free tier is enough for evaluation).
OPENROUTER_API_KEY=

# Optional overrides (defaults shown)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_LLM_SM=openrouter/free
# DEFAULT_LLM_MED=nvidia/nemotron-3-super-120b-a12b:free
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# LOG_LEVEL=INFO

# Where the running agent reaches the mock booking API.
# Use 127.0.0.1 in dev; in tests we invoke the graph in-process and this is unused.
MERIDIAN_API_BASE=http://127.0.0.1:8000/api/v1
